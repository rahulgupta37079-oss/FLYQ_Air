# ============ FLYQ — Environment Variables ============
# Copy to .env.local and fill with your own keys. Never commit real values.

NEXT_PUBLIC_SITE_URL=https://flyqdrone.in
NEXT_PUBLIC_ADMIN_SLUG=control-tower-x9k2

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ---- Payments (Razorpay) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_FROM=FLYQ <hello@flyqdrone.in>
ADMIN_NOTIFY_EMAIL=hello@flyqdrone.in

# ---- WhatsApp Cloud API ----
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
ADMIN_WHATSAPP=+919137361474

# ---- Shipping (Shiprocket) ----
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ---- reCAPTCHA v3 ----
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ---- Admin hardening ----
ADMIN_IP_ALLOWLIST=
ADMIN_TOTP_ISSUER=FLYQ
